# ─── LLM access ─────────────────────────────────────────────
# OpenRouter is the primary LLM provider (multi-model routing)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenAI is used directly for embeddings only (cheaper than via OpenRouter)
OPENAI_API_KEY=sk-...

# ─── Model routing (see ARCHITECTURE.md) ────────────────────
MODEL_SYNTHESIZER=anthropic/claude-opus-4-7
MODEL_RUBRIC_CRITIQUE=anthropic/claude-sonnet-4-6
MODEL_SAFETY_GUARD=anthropic/claude-haiku-4-5
MODEL_CAPABILITY_ROUTER=anthropic/claude-haiku-4-5
EMBEDDING_MODEL=text-embedding-3-small

# ─── Observability ──────────────────────────────────────────
# LangSmith tracing — set TRACING=true to enable.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=flo101-critic
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ─── App config ─────────────────────────────────────────────
LOG_LEVEL=INFO
SQLITE_PATH=/data/flo101.sqlite
CORPUS_DIR=/corpora
SANDBOX_TIMEOUT_SECONDS=5
SANDBOX_MEMORY_MB=256

# ─── Web ────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
