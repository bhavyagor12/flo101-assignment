# Copy to `.env` on the EC2 instance and fill real keys.

# Public web port exposed on the EC2 instance.
# Use 80 for a public demo. Use 3000 if another reverse proxy owns port 80.
WEB_PORT=80

# LLM access (OpenRouter handles chat + embeddings)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model routing
MODEL_SYNTHESIZER=anthropic/claude-opus-4-7
MODEL_RUBRIC_CRITIQUE=anthropic/claude-sonnet-4-6
MODEL_SAFETY_GUARD=anthropic/claude-haiku-4-5
MODEL_CAPABILITY_ROUTER=anthropic/claude-haiku-4-5
EMBEDDING_MODEL=openai/text-embedding-3-small

# Observability
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=flo101-critic
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# App config
LOG_LEVEL=INFO
SQLITE_PATH=/data/flo101.sqlite
CORPUS_DIR=/corpora
SANDBOX_TIMEOUT_SECONDS=5
SANDBOX_MEMORY_MB=256
EVALUATION_WALLCLOCK_SECONDS=90

# Browser API traffic is same-origin through the web container's `/api` proxy.
VITE_API_BASE_URL=/api
